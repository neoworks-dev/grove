{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "sdk/src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": [
      "electron-vite/node"
    ],
    "paths": {
      "@grove/plugin-sdk": [
        "./sdk/src/index.ts"
      ],
      "@grove/plugin-sdk/protocol": [
        "./sdk/src/protocol.ts"
      ]
    }
  }
}
