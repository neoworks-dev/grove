{
  "name": "grove",
  "version": "1.0.0",
  "description": "Grove — a git worktree editor",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "workspaces": [
    "sdk"
  ],
  "scripts": {
    "format": "prettier --plugin prettier-plugin-svelte --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "svelte-check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run svelte-check",
    "build:plugins": "bun scripts/build-plugins.ts",
    "fetch:nvim": "bun scripts/fetch-nvim.ts",
    "start": "electron-vite preview",
    "dev": "npm run build:plugins && npm run fetch:nvim && electron-vite dev",
    "build": "npm run typecheck && npm run build:plugins && npm run fetch:nvim && electron-vite build",
    "postinstall": "electron-builder install-app-deps && bun scripts/fetch-nvim.ts",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.204",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@iconify-json/vscode-icons": "^1.2.65",
    "@iconify/svelte": "^5.2.2",
    "@msgpack/msgpack": "^3.1.3",
    "@neoworks-dev/ui": "link:@neoworks-dev/ui",
    "@openai/codex-sdk": "0.143.0",
    "@opencode-ai/sdk": "1.17.15",
    "@vscode/ripgrep": "^1.18.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "dompurify": "^3.4.11",
    "electron-updater": "^6.3.9",
    "js-yaml": "^5.2.1",
    "marked": "^18.0.5",
    "node-pty": "^1.1.0",
    "phosphor-svelte": "^3.1.0",
    "simple-git": "^3.36.0",
    "tree-sitter-wasms": "^0.1.13",
    "vscode-jsonrpc": "^9.0.1",
    "vscode-languageserver-protocol": "^3.18.2",
    "vscode-languageserver-types": "^3.18.0",
    "web-tree-sitter": "0.24.7",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.19.1",
    "daisyui": "^5.6.15",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.13.1",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.0",
    "svelte": "^5.45.6",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
